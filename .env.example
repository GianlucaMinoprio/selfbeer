# SelfBeer configuration
PORT=3000
RELAY_GPIO=26
POUR_MS=15000
LCD_ADDRESS=0x27
STATUS_WEBHOOK_URL=

# Age verification (21 for US, 18 for Europe)
MINIMUM_AGE=21
# MINIMUM_AGE=18  # for my European friends

# ngrok tunnel (auto-starts on boot, gives you a public URL)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# NGROK_DOMAIN=selfbeer.ngrok.app  # optional: use a fixed ngrok domain (paid plan)

# If not using ngrok, set a manual endpoint URL
# ENDPOINT_URL=https://selfbeer.yourdomain.com/api/verify
