# SelfBeer Semaphore Frontend

# Backend verify endpoint (ngrok or Cloudflare tunnel URL)
NEXT_PUBLIC_ENDPOINT_URL=https://selfbeer.ngrok.app/api/verify

# Logo shown in Self app QR prompt
NEXT_PUBLIC_LOGO_URL=https://i.postimg.cc/kG8KkQCL/temp-Image-Byjart.avif

# Age verification (21 for US, 18 for Europe)
NEXT_PUBLIC_MINIMUM_AGE=21
# NEXT_PUBLIC_MINIMUM_AGE=18  # for my European friends

# Upstash Redis (required for status persistence on Vercel)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
